#!/bin/bash
# Please note that this file was generated by Qwen3.6-Plus

#SBATCH --job-name=fmriprep
#SBATCH --output=logs/sub-logs-%A_%a.log
#SBATCH --error=logs/sub-errors-%A_%a.log
#SBATCH --time=12:00:00
#SBATCH --mem=8G
#SBATCH --cpus-per-task=4
#SBATCH --array=1-10

SUBJECTS=(001 015 030 045 060 075 090 0105 0120 0135)

SUBJECT=${SUBJECTS[$((SLURM_ARRAY_TASK_ID - 1))]}

# Create log & work directories
mkdir -p logs
mkdir -p "./work/${SUBJECT}"

echo "Starting fmriprep for sub-${SUBJECT} (Task ${SLURM_ARRAY_TASK_ID})"

# 2️⃣ RUN DOCKER
docker run --rm \
  --cpus=${SLURM_CPUS_PER_TASK} \
  --memory=${SLURM_MEM_PER_NODE}m \
  -v "$(pwd)/data/flanker:/data:ro"\
  -v "$(pwd)/output:/out"\
  -v "$(pwd)/work/${SUBJECT}:/work"\
  -v "$(pwd)/license.txt:/opt/freesurfer/license.txt:ro"\
  fuzzy-fmriprep /data /out participant \
  --participant-label ${SUBJECT} \
  --skip-bids-validation \
  --md-only-boilerplate \
  --fs-no-reconall \
  --output-spaces MNI152NLin2009cAsym:res-2 \
  --skull-strip-fixed-seed \
  --stop-on-first-crash \
  --nthreads ${SLURM_CPUS_PER_TASK} \
  --omp-nthreads ${SLURM_CPUS_PER_TASK} \
  -w /work

echo "Finished sub-${SUBJECT}"
