#!/bin/bash
# Please note that this file was generated by Qwen3.6-Plus and fine tuned by myself

#SBATCH --job-name=fmriprep
#SBATCH --partition=naha
#SBATCH --output=logs/sub-logs-%A_%a.log
#SBATCH --error=logs/sub-errors-%A_%a.log
#SBATCH --time=12:00:00
#SBATCH --ntasks-per-node=1
#SBATCH --array=1-10%5

SUBJECTS=(001 015 030 045 060 075 090 105 120 135)

SUBJECT=${SUBJECTS[$((SLURM_ARRAY_TASK_ID - 1))]}

mkdir -p logs
mkdir -p "./work/${SUBJECT}"

echo "Starting fmriprep for sub-${SUBJECT} (Task ${SLURM_ARRAY_TASK_ID})"

docker run --rm \
    -u $(id -u):$(id -g) \
    -v "$(pwd)/data/reproduction-data:/data:ro"\
    -v "$(pwd)/output/run-1:/out/"\
    -v "$(pwd)/work/run-1-sub-${SUBJECT}:/work"\
    -v "$(pwd)/license.txt:/opt/freesurfer/license.txt:ro"\
    madeinshinea/fuzzy-fmriprep:25.2.5 /data /out participant \
    --participant-label ${SUBJECT} \
    --skip-bids-validation \
    --md-only-boilerplate \
    --fs-no-reconall \
    --output-spaces MNI152NLin2009cAsym:res-2 \
    --skull-strip-fixed-seed \
    --stop-on-first-crash \
    -w /work

echo "Finished sub-${SUBJECT}"
